rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Super admin = the root owner, OR any allowlisted user flagged admin == true.
    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'osahsh991@gmail.com'
        || (
          exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email))
          && get(/databases/$(database)/documents/allowlist/$(request.auth.token.email)).data.admin == true
        )
      );
    }
    function isAllowed() {
      return request.auth != null
        && exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email));
    }

    // Allowlist: anyone signed in may read it; only a super admin edits it.
    match /allowlist/{email} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // Access requests: a signed-in user may file one for their own email;
    // only a super admin can view/approve/deny them.
    match /accessRequests/{email} {
      allow create: if request.auth != null && request.auth.token.email == email;
      allow read, update, delete: if isSuperAdmin();
    }

    // App settings (e.g. the single storage Drive account): all users read; admins write.
    match /settings/{doc} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // Shared shop data: one database for the whole shop. Any allowlisted user (or super admin)
    // may read and write it. Covers shop/main and its subcollections (products/customers/
    // orders/payments/backups) plus the meta doc's lastChange field.
    match /shop/{document=**} {
      allow read, write: if request.auth != null && (isSuperAdmin() || isAllowed());
    }

    // Legacy per-user data (kept readable/writable for the owner; no longer used for new data).
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && (isSuperAdmin() || isAllowed());
    }
  }
}
