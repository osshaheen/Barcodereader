rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'osahsh991@gmail.com';
    }
    function isAllowed() {
      return request.auth != null
        && exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email));
    }

    // Allowlist: anyone signed in may check it; only the super admin edits it.
    match /allowlist/{email} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // Access requests: a signed-in user may file a request for their own email;
    // only the super admin can view/approve/deny them.
    match /accessRequests/{email} {
      allow create: if request.auth != null && request.auth.token.email == email;
      allow read, update, delete: if isSuperAdmin();
    }

    // App data: owner-only, and only if the super admin or an allowlisted user.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && (isSuperAdmin() || isAllowed());
    }
  }
}
