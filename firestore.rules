rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Login allowlist: any signed-in user may check emails; only you edit it from the console.
    match /allowlist/{email} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Each user can read/write ONLY their own data, and only if their email is allowlisted.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email));
    }
  }
}
